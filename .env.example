# WorldEconomy — optional API keys. Copy to `.env` (gitignored) and fill in.
# Everything degrades gracefully: a source/provider is simply skipped if its
# key is absent. Keys are read from here or the environment, never committed.

# --- data ---
# FRED (free): https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# --- AI cross-checking panel (`econ panel` / `econ crosscheck` / MCP econ_panel) ---
# Only the ones you set get polled. `econ panel-models` shows what's ready.
# A good free spread with breadth across labs (short aliases like `groq_api`
# also work, matching the FRED `fred_api` convention — matching is case-insensitive):
#   GROQ_API_KEY  -> free Llama-3.3 + Qwen3 + GPT-OSS-120B, 3 lineages, one key
#                    (https://console.groq.com/keys )
#   GITHUB_TOKEN  -> free GPT-4o-mini (GitHub Models: https://github.com/marketplace/models )
#   GOOGLE_API_KEY-> Gemini free tier (https://aistudio.google.com/apikey )
#   MISTRAL_API_KEY   -> Mistral free tier (https://console.mistral.ai/api-keys )
#   OPENROUTER_API_KEY-> many models incl. some :free (https://openrouter.ai/keys )
#   DEEPSEEK_API_KEY  -> DeepSeek direct, cheap (https://platform.deepseek.com )
# Paid, if you want the frontier flagships:
#   ANTHROPIC_API_KEY -> Claude  (https://console.anthropic.com/ )
#   OPENAI_API_KEY    -> GPT via OpenAI  (provider name: gpt-openai)
#   XAI_API_KEY       -> Grok  (https://console.x.ai/ )

ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
GITHUB_TOKEN=
GROQ_API_KEY=
XAI_API_KEY=
MISTRAL_API_KEY=
OPENROUTER_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=

# Optional per-provider model overrides (so a renamed model never breaks the panel):
#   PANEL_CLAUDE_MODEL=claude-haiku-4-5
#   PANEL_GEMINI_MODEL=gemini-2.5-flash
#   PANEL_GROK_MODEL=grok-2-latest
